{
  "name": "world-tree",
  "version": "0.5.0-product-experience-rebuild.0",
  "description": "World Tree — 本地优先、可保存和继续的 AI 世界与角色互动工作台",
  "type": "module",
  "main": "server.js",
  "bin": {
    "world-tree": "bin/world-tree.js"
  },
  "files": [
    "bin/",
    "server.js",
    "world-tree-console.html",
    "world-tree-console.css",
    "world-tree-client-core.js",
    "ui-labels.js",
    "world-tree-console.js",
    "browser/",
    "src/",
    "defaults/engine-profile/",
    "defaults/world-profiles/",
    "defaults/examples/",
    "README.md",
    "README.en.md",
    "SECURITY.md",
    "config.example.json",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "check": "node scripts/check.mjs",
    "test": "node scripts/test.mjs",
    "test:p0": "node --test tests/unit/living-world-kernel-p0.test.js",
    "test:p1": "node --test tests/unit/experience-stability-kernel-p1.test.js",
    "test:p2": "node --test tests/unit/long-play-kernel-p2.test.js",
    "test:kernel": "node --test tests/unit/kernel-turn-context.test.js tests/integration/kernel-completion.test.js",
    "test:prompts": "node --test tests/unit/prompt-*.test.js tests/integration/prompt-runtime-integration.test.js",
    "test:prompt-contracts": "node --test tests/unit/prompt-task-contracts.test.js tests/unit/prompt-runtime-identity.test.js tests/unit/llm-task-gateway.test.js",
    "test:feature-alias": "node --test tests/unit/feature-alias-registry.test.js",
    "ux:check": "node scripts/audit-ux-coherence.mjs",
    "test:llm-routing": "node --test tests/unit/prompt-task-contracts.test.js tests/unit/prompt-runtime-identity.test.js tests/unit/llm-task-gateway.test.js tests/unit/tabletop-v2-llm-polish.test.js tests/unit/detective-v2-llm-narration.test.js tests/unit/single-player-scriptkill-llm-dialogue.test.js",
    "test:legacy-mechanisms": "node --test tests/unit/creation-wizard.test.js tests/integration/legacy-mechanism-expansion.test.js",
    "test:assets": "node --test tests/unit/asset-status-matrix.test.js",
    "test:authority": "node --test tests/unit/authority-policy.test.js",
    "test:legacy-modernization": "node --test tests/unit/legacy-modernization.test.js",
    "test:workflow-readiness": "node --test tests/unit/workflow-context-envelope.test.js",
    "test:workflows": "node --test tests/unit/workflow-*.test.js tests/integration/workflow-*.test.js",
    "test:workflow-e2e": "node --test tests/integration/workflow-e2e.test.js",
    "workflow:check": "node scripts/validate-workflow-integration.mjs",
    "real-play:smoke": "node scripts/real-play-scenarios.mjs",
    "asset:check": "node scripts/validate-asset-inventory.mjs",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js",
    "audit": "node scripts/audit.mjs",
    "interface-audit": "node scripts/interface-audit.mjs",
    "docs:check": "node scripts/check-docs.mjs && node scripts/audit-doc-lifecycle.mjs",
    "test:character-v2": "node --test tests/unit/character-v2-text-core.test.js",
    "test:character-v2-ui": "node --test tests/unit/character-v2-advanced-ui-gate.test.js",
    "test:character-v2-capsule": "node --test tests/unit/character-v2-capsule-creation.test.js",
    "test:character-v2-capsule-service": "node --test tests/unit/character-capsule-service.test.js",
    "test:character-v2-capsule-ui": "node --test tests/unit/character-v2-create-ui-state.test.js",
    "test:character-v2-runtime": "node --test tests/unit/character-v2-runtime-context.test.js",
    "test:character-v2-runtime-mvp": "node --test tests/unit/character-v2-prompt-packet-preview.test.js tests/unit/character-v2-runtime-candidates.test.js tests/unit/character-v2-runtime-mvp.test.js",
    "test:character-v2-live": "node --test tests/unit/character-v2-live-runtime-turn.test.js tests/unit/character-v2-live-turn-service.test.js tests/unit/character-v2-live-ui-state.test.js",
    "test:character-v2-final": "node --test tests/unit/character-v2-live-runtime-turn.test.js tests/unit/character-v2-live-turn-service.test.js tests/unit/character-v2-live-ui-state.test.js tests/unit/character-v2-candidate-workbench.test.js tests/unit/character-v2-export-service.test.js",
    "test:character-v2-long-term": "npm run test:character-v2-final && node --test tests/unit/character-v2-long-term-end-to-end.test.js tests/unit/character-v2-runtime-context-long-term.test.js",
    "test:entry-closures": "node scripts/audit-entry-closures.mjs",
    "test:world-tree-v2-entries": "npm run test:tabletop-v2-full && npm run test:detective-v2-full && npm run test:character-v2-long-term && npm run test:entry-closures && npm run test:final-v2-closures",
    "test:final-v2-closures": "node scripts/audit-world-tree-v2-final-closures.mjs",
    "test:single-player-scriptkill-v2": "node --test tests/unit/single-player-scriptkill-v2-package.test.js tests/unit/single-player-scriptkill-v2-importer.test.js tests/unit/single-player-scriptkill-v2-runtime.test.js tests/unit/single-player-scriptkill-v2-knowledge-boundary.test.js tests/unit/single-player-scriptkill-v2-service-e2e.test.js",
    "test:single-player-scriptkill-v2-audit": "node scripts/audit-single-player-scriptkill-v2-closure.mjs",
    "test:tabletop-v2-foundation": "node --test tests/unit/tabletop-v2-dice-engine.test.js tests/unit/tabletop-v2-ruleset-profile.test.js tests/unit/tabletop-v2-adventure-module.test.js tests/unit/tabletop-v2-clock-engine.test.js",
    "test:tabletop-v2-runtime": "node --test tests/unit/tabletop-v2-turn-ruling.test.js tests/unit/tabletop-v2-save-branch.test.js tests/unit/tabletop-v2-ending-summary.test.js tests/unit/tabletop-v2-service.test.js",
    "test:tabletop-v2": "npm run test:tabletop-v2-foundation && npm run test:tabletop-v2-runtime",
    "test:tabletop-v2-server-routes": "node --test tests/unit/tabletop-v2-server-routes.test.js",
    "test:tabletop-v2-module-importer": "node --test tests/unit/tabletop-v2-module-importer.test.js",
    "test:tabletop-v2-state-mutation": "node --test tests/unit/tabletop-v2-state-mutation.test.js",
    "test:tabletop-v2-gm-loop": "node --test tests/unit/tabletop-v2-gm-loop.test.js",
    "test:tabletop-v2-hidden-leak": "node --test tests/unit/tabletop-v2-hidden-leak.test.js",
    "test:tabletop-v2-asset-resolver": "node --test tests/unit/tabletop-v2-asset-resolver.test.js",
    "test:tabletop-v2-full": "npm run test:tabletop-v2 && npm run test:tabletop-v2-server-routes && npm run test:tabletop-v2-module-importer && npm run test:tabletop-v2-state-mutation && npm run test:tabletop-v2-gm-loop && npm run test:tabletop-v2-hidden-leak && npm run test:tabletop-v2-asset-resolver",
    "test:detective-v2-foundation": "node --test tests/unit/detective-v2-case-capsule.test.js tests/unit/detective-v2-truth-ledger.test.js tests/unit/detective-v2-evidence-registry.test.js tests/unit/detective-v2-testimony-registry.test.js tests/unit/detective-v2-player-notebook.test.js tests/unit/detective-v2-deduction-report.test.js tests/unit/detective-v2-case-generator-blueprint.test.js tests/unit/detective-v2-asset-links-isolation.test.js",
    "test:detective-v2-runtime": "node --test tests/unit/detective-v2-case-importer.test.js tests/unit/detective-v2-run-state.test.js tests/unit/detective-v2-runtime-engine.test.js tests/unit/detective-v2-service.test.js tests/unit/detective-v2-hidden-leak.test.js",
    "test:detective-v2": "npm run test:detective-v2-foundation && npm run test:detective-v2-runtime",
    "test:detective-v2-case-generator": "node --test tests/unit/detective-v2-case-generator.test.js",
    "test:detective-v2-full": "npm run test:detective-v2 && npm run test:detective-v2-case-generator",
    "legacy:check": "node scripts/check-legacy-status.mjs",
    "preflight": "node scripts/audit.mjs && node scripts/check.mjs && npm run docs:check && npm run asset:check && npm run test:p0 && npm run test:p1 && npm run test:p2 && npm run test:kernel && npm run test:prompts && npm run test:feature-alias && npm run test:llm-routing && npm run ux:check && npm run test:legacy-mechanisms && npm run test:assets && npm run test:authority && npm run test:legacy-modernization && npm run test:workflow-readiness && npm run workflow:check && npm run test:workflows && npm run quality:governance && npm run test:unit && npm run test:integration && npm run test:v2-route-registry && npm run test:console-boundary && npm run test:v2-product-playable && npm run test:world-tree-v2-entries && npm run test:single-player-scriptkill-v2 && npm run test:single-player-scriptkill-v2-audit && npm run test:project-complete-audit && npm run interface-audit",
    "test:project-complete-audit": "node scripts/audit-world-tree-project-complete.mjs",
    "test:strategy-sim-v2": "node --test tests/unit/strategy-sim-spec.test.js tests/unit/strategy-sim-run-state.test.js tests/unit/strategy-sim-public-view-scrubber.test.js tests/unit/strategy-sim-turn-engine.test.js tests/unit/strategy-sim-probability-roll-record.test.js tests/unit/strategy-numeric-system.test.js tests/unit/strategy-probability-system.test.js tests/unit/strategy-v2-ready.test.js",
    "test:worldbook-v2": "node --test tests/unit/worldbook-v2-*.test.js",
    "test:worldbook-v2-product": "node --test tests/unit/worldbook-v2-product-service.test.js",
    "test:strategy-sim-v2-product": "node --test tests/unit/strategy-sim-v2-product-service.test.js",
    "test:v2-product-playable": "node --test tests/unit/worldbook-v2-product-service.test.js tests/unit/strategy-sim-v2-product-service.test.js tests/unit/tabletop-v2-product-closure.test.js tests/unit/detective-v2-product-closure.test.js tests/unit/single-player-scriptkill-v2-product-closure.test.js tests/integration/v2-product-playable-routes.test.js tests/integration/v2-product-playable-roundtrip.test.js",
    "test:llm-prompts": "node --test tests/unit/llm-prompt-audit.test.js",
    "audit:architecture-debt": "node scripts/audit-architecture-debt.mjs",
    "audit:v2-product-playable": "node scripts/audit-v2-product-playable-closure.mjs",
    "release:verify": "node scripts/release-verify.mjs",
    "smoke:v2-product-playable-api": "node scripts/smoke-v2-product-playable-api.mjs",
    "smoke:v2-product-shell-browser": "node scripts/smoke-v2-product-shell-browser.mjs",
    "test:alchemy-closure": "node --test tests/unit/alchemy-capabilities.test.js tests/unit/alchemy-planner-service.test.js tests/unit/alchemy-generation-service.test.js tests/unit/alchemy-localizer-service.test.js tests/unit/alchemy-delivery-service.test.js tests/unit/alchemy-server-route-contract.test.js tests/unit/alchemy-console-g1-ui.test.js tests/integration/alchemy-engineering-closure.test.js",
    "smoke:user-content-api": "node scripts/smoke-user-content-api.mjs",
    "test:user-content-browser-smoke": "node scripts/run-user-content-browser-smoke.mjs",
    "smoke:product-entry-browser-matrix": "node scripts/smoke-product-entry-browser-matrix.mjs",
    "smoke:user-content-real-llm": "node scripts/smoke-user-content-real-llm.mjs",
    "smoke:first-play": "node scripts/smoke-first-play.mjs",
    "narrative:eval": "node scripts/narrative-eval.mjs --dry-run",
    "self-report": "node scripts/self-report.mjs",
    "quality:governance": "npm run narrative:eval && node --test tests/unit/quality-governance.test.js",
    "truth:check": "node scripts/check-truth-source-sync.mjs",
    "facts:generate": "node scripts/generate-project-facts.mjs",
    "facts:check": "node scripts/generate-project-facts.mjs --check output/project-facts.json",
    "snapshot:safe": "node scripts/snapshot-safe.mjs",
    "verify:coverage": "node --test --experimental-test-coverage --test-coverage-exclude=tests/** --test-coverage-exclude=scripts/** --test-coverage-lines=70 --test-coverage-functions=70 --test-coverage-branches=60 tests/unit/*.test.js tests/integration/*.test.js",
    "verify:fast": "npm run check && npm run test:p0 && npm run test:feature-alias && npm run docs:check && npm run truth:check",
    "verify:pr": "npm run verify:fast && npm run test:unit && npm run test:integration && npm run test:console-boundary && npm run release:verify",
    "verify:release": "npm run preflight && npm run facts:generate && npm run release:verify && npm run smoke:first-play && npm run smoke:product-entry-browser-matrix && npm run snapshot:safe",
    "verify:nightly": "node scripts/verify-nightly.mjs",
    "ci:github-actions-checks": "node scripts/verify-github-actions-checks.mjs",
    "test:v2-route-registry": "node --test tests/unit/v2-product-route-registry.test.js",
    "test:console-boundary": "node scripts/check-browser-boundaries.mjs && node --test tests/unit/console-client-core.test.js tests/unit/browser-architecture.test.js",
    "docs:lifecycle:check": "node scripts/audit-doc-lifecycle.mjs"
  },
  "keywords": [
    "world-tree",
    "narrative-engine",
    "ai-storytelling",
    "local-first",
    "interactive-fiction"
  ],
  "author": "World Tree",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HatayaMisuzu/world-tree.git"
  },
  "devDependencies": {
    "playwright": "^1.61.1"
  }
}
